# Copy to .env for local development. On a host, set these as environment
# variables in the host's dashboard instead of committing them.

# Required
DISCORD_BOT_TOKEN=your_bot_token_here
TARGET_USER_ID=123456789012345678

# AI provider (OpenAI-compatible). Defaults below target Groq (free).
# Get a free Groq key at https://console.groq.com/keys
AI_API_KEY=your_ai_api_key
AI_MODEL=qwen/qwen3-32b
AI_BASE_URL=https://api.groq.com/openai/v1

# Web search (DuckDuckGo, free, no key): the model searches the web when a
# question needs current info. Set to false to disable.
# ENABLE_WEB_SEARCH=true
# If you hit 429 often (free TPM = 6000/min), use a lighter model:
#   AI_MODEL=llama-3.1-8b-instant

# Alternative provider (note: web search needs a model that supports tool calls):
#   Gemini: AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai   AI_MODEL=gemini-2.0-flash

# Optional: voice for /ftts (edge-tts). Thai: th-TH-NiwatNeural (male),
# th-TH-PremwadeeNeural (female). Defaults to the male voice.
# TTS_VOICE=th-TH-NiwatNeural

# Optional: only needed for voice /ftts if ffmpeg is not on PATH
# FFMPEG_PATH=C:\path\to\ffmpeg.exe
